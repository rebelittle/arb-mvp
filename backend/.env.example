# Backend env
CORS_ORIGINS=http://localhost:5173
ENABLE_MOCK_SOURCE=true
ENABLE_ODDS_API_SOURCE=false
ENABLE_SCRAPLING_SOURCE=true

# Optional odds API adapter
ODDS_API_KEY=
ODDS_API_SPORT=basketball_nba

# Comma-separated sportsbook names for Scrapling adapter
SCRAPLING_BOOKS=draftkings,fanduel,betrivers,betmgm

# API key auth (leave empty to disable auth in local dev)
API_KEY=

# Sports to scrape (comma-separated)
SPORTS=kbo,nba,mlb,nhl,soccer,ncaam

# Scrape intervals (seconds)
# Playwright scrapers (DraftKings/FanDuel/BetMGM) scrape 1 sport (ncaam) = ~15s run
PLAYWRIGHT_INTERVAL_SECONDS=10
# Kambi API scrapers (BetRivers/betPARX/BallyBet) ~9s run → 14s total cycle
API_INTERVAL_SECONDS=5

# Per-book credentials
DRAFTKINGS_EMAIL=
DRAFTKINGS_PASSWORD=
FANDUEL_EMAIL=
FANDUEL_PASSWORD=

# BetRivers state subdomain (oh=Ohio, il=Illinois, pa=Pennsylvania, mi=Michigan, etc.)
BETRIVERS_STATE=oh

# betPARX state (pa=Pennsylvania, nj=New Jersey, mi=Michigan, md=Maryland)
BETPARX_STATE=pa
